    "@tsconfig/svelte": "^5.0.4",
    "@types/bun": "^1.1.14",
    "@types/papaparse": "^5.3.15",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
