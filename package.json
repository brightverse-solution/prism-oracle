{
  "name": "prism-oracle",
  "version": "0.1.0",
  "description": "PRISM Oracle 🎨 — Frontend quotation preview (refracts FORGE's xlsx into a browser page)",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "bun test ./tests/*.test.ts",
